<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="containerVBox" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane fx:id="headerGridPane" hgap="8" styleClass="application-list-header" VBox.vgrow="NEVER">
    <padding>
      <Insets top="8" right="20" bottom="8" left="20"/>
    </padding>
    <columnConstraints>
      <ColumnConstraints percentWidth="5.4"/>
      <ColumnConstraints percentWidth="13.4"/>
      <ColumnConstraints percentWidth="23.5"/>
      <ColumnConstraints percentWidth="17.5"/>
      <ColumnConstraints percentWidth="13.4"/>
      <ColumnConstraints percentWidth="26.8"/>
    </columnConstraints>

    <Label text="ID" GridPane.columnIndex="0" styleClass="application-list-header-label"/>
    <Label text="COMPANY" GridPane.columnIndex="1" styleClass="application-list-header-label"/>
    <Label text="ROLE" GridPane.columnIndex="2" styleClass="application-list-header-label"/>
    <Label text="STATUS" GridPane.columnIndex="3" styleClass="application-list-header-label"/>
    <Label text="DATE" GridPane.columnIndex="4" styleClass="application-list-header-label">
      <GridPane.margin>
        <Insets left="12"/>
      </GridPane.margin>
    </Label>
    <Label text="URL" GridPane.columnIndex="5" styleClass="application-list-header-label">
      <GridPane.margin>
        <Insets left="12"/>
      </GridPane.margin>
    </Label>
  </GridPane>

  <ListView fx:id="applicationListView" VBox.vgrow="ALWAYS" />
</VBox>
