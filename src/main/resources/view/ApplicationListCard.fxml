<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>

<HBox id="cardPane" fx:id="cardPane" maxWidth="Infinity"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane fx:id="cardGridPane" HBox.hgrow="ALWAYS" hgap="8" maxWidth="Infinity">
    <padding>
      <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <columnConstraints>
      <ColumnConstraints percentWidth="5"/>     <!-- ID -->
      <ColumnConstraints percentWidth="16"/>    <!-- Company -->
      <ColumnConstraints percentWidth="19"/>    <!-- Role -->
      <ColumnConstraints percentWidth="10"/>    <!-- Status -->
      <ColumnConstraints percentWidth="16"/>    <!-- Date -->
      <ColumnConstraints percentWidth="15"/>    <!-- URL -->
      <ColumnConstraints percentWidth="19"/>    <!-- Note -->
    </columnConstraints>

    <!-- ID -->
    <Label fx:id="id"
           GridPane.columnIndex="0"
           styleClass="cell_index_label"/>

    <!-- Company -->
    <Label fx:id="company"
           GridPane.columnIndex="1"
           styleClass="cell_big_label"
           wrapText="true"/>

    <!-- Role -->
    <Label fx:id="role"
           GridPane.columnIndex="2"
           styleClass="cell_mid_label"
           wrapText="true"/>

    <!-- Status -->
    <Label fx:id="status"
           GridPane.columnIndex="3"
           styleClass="status"/>

    <!-- Date -->
    <Label fx:id="applicationDate"
           GridPane.columnIndex="4"
           styleClass="date-label">
      <GridPane.margin>
        <Insets left="12"/>
      </GridPane.margin>
    </Label>

    <!-- URL -->
    <Label fx:id="url"
           GridPane.columnIndex="5"
           styleClass="url-label"
           wrapText="true">
      <GridPane.margin>
        <Insets left="12"/>
      </GridPane.margin>
    </Label>

    <!-- Note -->
    <Label fx:id="note"
           GridPane.columnIndex="6"
           styleClass="note-label"
           wrapText="true">
      <GridPane.margin>
        <Insets left="12"/>
      </GridPane.margin>
    </Label>
  </GridPane>
</HBox>
